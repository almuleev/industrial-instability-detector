root = true

[*.py]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{md,yml,yaml,toml,ini,txt}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{png,jpg,jpeg,svg,zip,joblib}]
insert_final_newline = false
trim_trailing_whitespace = false
